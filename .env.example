# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nestjs_starter
DATABASE_SSL=false
DATABASE_LOGGING=false
# Auto-sync the schema from entities. Convenient in development; ALWAYS keep
# this false in production and use migrations instead (it is force-disabled
# when NODE_ENV=production regardless of this value).
DATABASE_SYNCHRONIZE=false

# Authentication — generate strong secrets, e.g. `openssl rand -base64 48`
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_secure_random_string_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — the single browser origin allowed to call the API with credentials
FRONTEND_URL=http://localhost:3001

# API docs (Swagger). Served at /docs. Force-disabled in production.
SWAGGER_ENABLED=true

# OAuth (optional) — leave the client id blank to disable a provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback
